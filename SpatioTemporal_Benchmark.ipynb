   "source": [
    "## 1. Generate Realistic Spatio-Temporal Event Data\n",
    "\n",
    "We simulate a scenario similar to defense/intelligence predictive analytics:\n",
    "- Events happening across a geographic area (think: a city or region)\n",
    "- Each event has: lat, lon, timestamp, event type\n",
    "- **Target:** predict whether a location-time will have a high-risk incident\n",
    "- Events have spatial hotspots (some areas are riskier) and temporal patterns (time-of-day, day-of-week effects)\n",
    "\n",
    "This is the same structure as the BigBear.ai work — spatio-temporal risk prediction."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "def generate_spatiotemporal_data(n_events=20000):\n",
    "    \"\"\"\n",
    "    Generate synthetic spatio-temporal events with realistic patterns:\n",
    "    - Spatial hotspots (clustered risk zones)\n",
    "    - Temporal patterns (higher risk at night, weekends)\n",
    "    - Mixed signal: some events predictable, some random\n",
    "\n",
    "    Target: 1 = high-risk incident, 0 = normal event\n",
    "    \"\"\"\n",
    "    # Geographic area: roughly a 100km x 100km region\n",
    "    # Center around Washington DC area (BigBear.ai is defense-focused)\n",
    "    center_lat, center_lon = 38.9, -77.0\n",
    "    lat_spread, lon_spread = 0.5, 0.6  # ~50km spread\n",
    "\n",
    "    # Define spatial hotspots (risk zones)\n",
    "    hotspots = [\n",
    "        {\"lat\": 38.85, \"lon\": -77.05, \"radius\": 0.08, \"risk_boost\": 0.4},\n",
    "        {\"lat\": 39.05, \"lon\": -76.85, \"radius\": 0.06, \"risk_boost\": 0.5},\n",
    "        {\"lat\": 38.75, \"lon\": -77.20, \"radius\": 0.10, \"risk_boost\": 0.35},\n",
    "        {\"lat\": 39.10, \"lon\": -77.15, \"radius\": 0.05, \"risk_boost\": 0.55},\n",
    "    ]\n",
    "\n",
    "    # Time range: 6 months of data\n",
    "    start_date = datetime(2024, 1, 1)\n",
    "    date_range_days = 180\n",
    "\n",
    "    records = []\n",
    "    for i in range(n_events):\n",
    "        # Random location (with some clustering around hotspots)\n",
    "        if np.random.random() < 0.4:  # 40% of events near hotspots\n",
    "            hs = hotspots[np.random.randint(len(hotspots))]\n",
    "            lat = hs[\"lat\"] + np.random.randn() * hs[\"radius\"]\n",
    "            lon = hs[\"lon\"] + np.random.randn() * hs[\"radius\"]\n",
    "        else:\n",
    "            lat = center_lat + np.random.randn() * lat_spread\n",
    "            lon = center_lon + np.random.randn() * lon_spread\n",
    "\n",
    "        # Random timestamp with temporal patterns\n",
    "        day_offset = np.random.random() * date_range_days\n",
    "        hour = np.random.choice(24, p=[\n",
    "            0.02, 0.015, 0.015, 0.015, 0.02, 0.025,  # 0-5am (low)\n",
    "            0.04, 0.05, 0.06, 0.06, 0.06, 0.06,       # 6-11am (medium)\n",
    "            0.06, 0.06, 0.06, 0.055, 0.05, 0.05,      # 12-5pm (medium)\n",
    "            0.05, 0.05, 0.04, 0.035, 0.03, 0.025       # 6-11pm (declining)\n",
    "        ])\n",
    "        minute = np.random.randint(60)\n",
    "        ts = start_date + timedelta(days=day_offset, hours=hour, minutes=minute)\n",
    "\n",
    "        # Compute risk probability based on spatial + temporal factors\n",
    "        base_risk = 0.15  # 15% base rate\n",
    "\n",
    "        # Spatial risk: proximity to hotspots\n",
    "        spatial_risk = 0\n",
    "        for hs in hotspots:\n",
    "            dist = math.sqrt((lat - hs[\"lat\"])**2 + (lon - hs[\"lon\"])**2)\n",
    "            if dist < hs[\"radius\"] * 2:\n",
    "                spatial_risk = max(spatial_risk,\n",
    "                                   hs[\"risk_boost\"] * (1 - dist / (hs[\"radius\"] * 2)))\n",
    "\n",
    "        # Temporal risk: higher at night (22-4am), weekends\n",
    "        temporal_risk = 0\n",
    "        if hour >= 22 or hour <= 4:\n",
    "            temporal_risk += 0.15\n",
    "        if ts.weekday() >= 5:  # weekend\n",
    "            temporal_risk += 0.08\n",
    "\n",
    "        # Combined risk (with interaction)\n",
    "        risk_prob = base_risk + spatial_risk + temporal_risk + spatial_risk * temporal_risk * 0.5\n",
    "        risk_prob = min(risk_prob, 0.85)  # cap\n",
    "\n",
    "        # Add noise\n",
    "        risk_prob += np.random.randn() * 0.05\n",
    "        risk_prob = np.clip(risk_prob, 0, 1)\n",
    "\n",
    "        is_incident = 1 if np.random.random() < risk_prob else 0\n",
    "\n",
    "        records.append({\n",
    "            \"lat\": lat,\n",
    "            \"lon\": lon,\n",
    "            \"timestamp\": ts,\n",
    "            \"hour\": hour,\n",
    "            \"day_of_week\": ts.weekday(),\n",
    "            \"month\": ts.month,\n",
    "            \"is_incident\": is_incident,\n",
    "        })\n",
    "\n",
    "    df = pd.DataFrame(records)\n",
    "    print(f\"Generated {len(df):,} events\")\n",
    "    print(f\"Incident rate: {df['is_incident'].mean():.1%}\")\n",
    "    print(f\"Lat range: [{df['lat'].min():.3f}, {df['lat'].max():.3f}]\")\n",
    "    print(f\"Lon range: [{df['lon'].min():.3f}, {df['lon'].max():.3f}]\")\n",
    "    print(f\"Date range: {df['timestamp'].min().date()} to {df['timestamp'].max().date()}\")\n",
    "    return df\n",
    "\n",
    "df = generate_spatiotemporal_data(20000)"
   ]
  },
